<mvc:View controllerName="com.9b.traceability.controller.Traceability" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:f="sap.f"
	xmlns:commons="sap.suite.ui.commons" xmlns:core="sap.ui.core" xmlns:layout="sap.ui.layout" xmlns:table="sap.ui.table"
	xmlns:fb="sap.ui.comp.filterbar" xmlns:tnt="sap.tnt">
	<f:DynamicPage id="dynamicPageId" showFooter="true" class="dyPage">
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="Traceability"/>
				</f:heading>
				<f:content>
					<!--<FlexBox direction="Row" justifyContent="SpaceAround" alignItems="Center">-->
					<!--	<Text text="Navigate to: " width="5rem"></Text>-->
					<!--	<Select id="navigate" width="14rem" change="onChanageNavigate" forceSelection="false">-->
					<!--		<core:Item key="Strain" text="{i18n>Strain}"/>-->
					<!--		<core:Item key="PhenoTrack" text="Pheno Track"/>-->
					<!--		<core:Item key="MicroPropagation" text="Micro Propagation"/>-->
					<!--		<core:Item key="MacroPropagation" text="Macro Propagation"/>-->
					<!--		<core:Item key="MotherPlanner" text="{i18n>MotherPlanner}"/>-->
					<!--		<core:Item key="Cultivation" text="Cultivation"/>-->
					<!--<core:Item key="DestroyedPlants" text="{i18n>DestroyedPlants}"/>-->
					<!--		<core:Item key="Waste" text="{i18n>RecordWaste}"/>-->
					<!--	</Select>-->
					<!--</FlexBox>-->
				</f:content>
				<f:actions>
					<Button icon="sap-icon://refresh" press="onRefresh" tooltip="Refresh Data"/>
				</f:actions>
				<f:navigationActions>
					<Button text="{jsonModel>/refreshText}" type="Transparent" enabled="false" class="lastUpdate" width="11.5rem"/>
				</f:navigationActions>
			</f:DynamicPageTitle>
		</f:title>
		<f:content>
			<FlexBox height="100%" class="fullHeight" direction="Column">
				<table:Table id="traceabilityTable" selectionMode="MultiToggle" visibleRowCountMode="Auto" rows="{jsonModel>/destroyedPlantsData}"
					cellClick="cellClick">
					<table:extension>
						<OverflowToolbar>
							<Title class="tableTitle" id="tableHeader" text="{i18n>Items}"/>
							<ToolbarSpacer/>
							<MultiInput width="25rem" placeholder="{i18n>Search}" tokenUpdate="tokenUpdateMultiInput" submit="onSubmitMultiInput" showValueHelp="false"
								liveChange="onChangeMultiInput" id="searchFieldTable" enableMultiLineMode="true"/>
							<Button text="{i18n>ClearAllFilters}" press="clearAllFilters"/>
						</OverflowToolbar>
					</table:extension>
					<table:columns>
						<table:Column sortProperty="CreateDate" filterProperty="CreateDate">
							<Label text="Date Time" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>CreateDate}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="Creator" filterProperty="Creator">
							<Label text="Created By" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>Creator}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_PlantID" filterProperty="U_PlantID">
							<Label text="Plant ID" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_PlantID}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_BatchId" filterProperty="U_BatchId">
							<Label text="Batch ID" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_BatchId}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_RootBatchId" filterProperty="U_RootBatchId">
							<Label text="Root Batch ID" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_RootBatchId}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_ParentBatchId" filterProperty="U_ParentBatchId">
							<Label text="Parent Batch ID" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_ParentBatchId}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_ItemCode" filterProperty="U_ItemCode">
							<Label text="Item Code" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_ItemCode}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_ItemName" filterProperty="U_ItemName">
							<Label text="Item Name" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_ItemName}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_Phase" filterProperty="U_Phase">
							<Label text="Phase" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_Phase}" wrapping="false"/>
							</table:template>
						</table:Column>
						<table:Column sortProperty="U_PhaseSequence" filterProperty="U_PhaseSequence">
							<Label text="Phase Sequence" design="Bold"/>
							<table:template>
								<Text text="{jsonModel>U_PhaseSequence}" wrapping="false"/>
							</table:template>
						</table:Column>
						<!--<table:Column sortProperty="U_GoodsReceiptRef" filterProperty="U_GoodsReceiptRef">-->
						<!--	<Label text="Goods Receipt Ref" design="Bold"/>-->
						<!--	<table:template>-->
						<!--		<Text text="{jsonModel>U_GoodsReceiptRef}" wrapping="false"/>-->
						<!--	</table:template>-->
						<!--</table:Column>-->
					</table:columns>
				</table:Table>
			</FlexBox>
		</f:content>
		<f:footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Text text="{jsonModel>/versionInfo}"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>