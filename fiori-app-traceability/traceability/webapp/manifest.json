{
	"_version": "1.12.0",
	"sap.app": {
		"id": "com.9b.traceability",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"sourceTemplate": {
			"id": "servicecatalog.connectivityComponentForManifest",
			"version": "0.0.0"
		},
		"dataSources": {
			"seeds": {
				"uri": "/SB_R/Planner.xsodata",
				"type": "OData",
				"settings": {
					"localUri": "localService/metadata.xml"
				}
			},
			"releaseLog": {
				"uri": "model/releaseLog.json",
				"type": "JSON"
			}
		}
	},
	"sap.ui": {
		"fullWidth": true,
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": false,
		"rootView": {
			"viewName": "com.9b.traceability.view.App",
			"type": "XML",
			"async": true,
			"id": ""
		},
		"dependencies": {
			"minUI5Version": "1.65.6",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.ui.layout": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.9b.traceability.i18n.i18n"
				}
			},
			"": {
				"type": "sap.ui.model.odata.v2.ODataModel",
				"settings": {
					"defaultOperationMode": "Server",
					"defaultBindingMode": "TwoWay",
					"defaultCountMode": "None",
					"defaultUpdateMethod": "MERGE",
					"useBatch": false,
					"json": true
				},
				"dataSource": "seeds"
			},
			"releaseLog": {
				"type": "sap.ui.model.json.JSONModel",
				"dataSource": "releaseLog"
			}
		},
		"resources": {
			"css": [{
				"uri": "css/style.css"
			}]
		},
		"routing": {
			"config": {
				"routerClass": "sap.f.routing.Router",
				"viewType": "XML",
				"async": true,
				"viewPath": "com.9b.traceability.view",
				"controlAggregation": "pages",
				"controlId": "app",
				"clearControlAggregation": false,
				"bypassed": {
					"target": []
				}
			},
			"routes": [{
				"name": "traceability",
				"pattern": "",
				"titleTarget": "",
				"greedy": false,
				"target": [
					"traceability"
				]
			}],
			"targets": {
				"traceability": {
					"viewType": "XML",
					"transition": "slide",
					"clearControlAggregation": true,
					"viewName": "Traceability",
					"controlAggregation": "pages"
				}
			}
		}
	}
}